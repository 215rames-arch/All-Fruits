rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && (request.auth.token.email == '215rames@gmail.com' || request.auth.token.email == '214nit@gmail.com');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Fruit Validation ---
    function isValidFruit(data) {
      return data.keys().hasAll(['name', 'price', 'unit', 'category', 'image']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price > 0 &&
             data.unit is string &&
             data.category is string &&
             data.image is string;
    }

    // --- Fruits Collection ---
    match /fruits/{fruitId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin() && isValidFruit(incoming());

      // --- Reviews Subcollection ---
      function isValidReview(data) {
        return data.keys().hasAll(['userId', 'userName', 'rating', 'comment', 'createdAt']) &&
               data.userId == request.auth.uid &&
               data.rating is number && data.rating >= 1 && data.rating <= 5 &&
               data.comment is string && data.comment.size() > 0 && data.comment.size() <= 1000 &&
               data.createdAt is timestamp;
      }

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidReview(incoming());
        allow update: if isSignedIn() && isOwner(existing().userId) && isValidReview(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'comment']);
        allow delete: if isSignedIn() && isOwner(existing().userId);
      }
    }

    // --- User Profile Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() > 0;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    // --- Order Validation ---
    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'email', 'items', 'subtotal', 'savings', 'totalAmount', 'status', 'paymentMethod', 'shippingAddress', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
             data.items is list && data.items.size() > 0 &&
             data.paymentMethod in ['card', 'paypal', 'apple-pay', 'google-pay'] &&
             data.shippingAddress is map &&
             data.createdAt is timestamp;
    }

    match /orders/{orderId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if (isSignedIn() && isOwner(existing().userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                      existing().status == 'pending' &&
                      incoming().status == 'cancelled') || isAdmin();
    }
  }
}
